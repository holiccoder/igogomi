{% liquid
  assign is_pre_sale_product = false
  if product.handle == 'igogomi-cuv-i5-20-all-terrain-utility-e-bike'
    assign is_pre_sale_product = true
  endif
%}

<div
  id="Price-{{ section.id }}"
  class="no-js-hidden"
  role="status"
>
  {% if is_pre_sale_product %}
    <style>
      #Price-{{ section.id }} .pre-sale-price-row {
        display: inline-flex;
        align-items: center;
        gap: 10px;
      }
      #Price-{{ section.id }} .pre-sale-badge {
        display: inline-block;
        padding: 2px 10px;
        border: 1px solid #b8860b;
        border-radius: 999px;
        color: #b8860b;
        font-size: 16px;
        font-weight: 600;
        line-height: 1.3;
      }
    </style>
  {% endif %}
  <div class="variant-price">
    {% if is_pre_sale_product %}<span class="pre-sale-price-row">{% endif %}
    {% render 'price', product: product, use_variant: product.selected_or_first_available_variant, show_badges: true %}
    {% if is_pre_sale_product %}<span class="pre-sale-badge">Pre Sale</span></span>{% endif %}
  </div>
</div>

{% if block.settings.show_taxes_notice %}
  <div class="text-sm text-foreground/60 mt-1">
    {%- if cart.taxes_included -%}
      {{ 'products.product.include_taxes' | t }}
    {%- else -%}
      {{ 'products.product.exclude_taxes' | t }}
    {%- endif -%}
  </div>
{% endif %}
