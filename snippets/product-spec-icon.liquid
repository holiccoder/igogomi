{% liquid
  assign icon_name = icon | default: 'acceleration'
  assign icon_class = class | default: 'product-specs__icon'
  assign icon_alt = alt | default: ''
%}

{% if custom_icon != blank %}
  {{
    custom_icon
    | image_url: width: 80
    | image_tag: class: icon_class, widths: '40, 80', sizes: '40px', alt: icon_alt
  }}
{% else %}
  {% case icon_name %}
    {% when 'acceleration' %}
      <svg class="{{ icon_class }}" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
        <path d="M13 2L3 14h7l-1 8 10-12h-7l1-8z"/>
      </svg>
    {% when 'motor' %}
      <svg class="{{ icon_class }}" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
        <circle cx="12" cy="12" r="9"/>
        <path d="M12 8v4l3 2"/>
      </svg>
    {% when 'torque' %}
      <svg class="{{ icon_class }}" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
        <circle cx="12" cy="12" r="9"/>
        <path d="M8 12h8M12 8v8"/>
      </svg>
    {% when 'top_speed' %}
      <svg class="{{ icon_class }}" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
        <path d="M4 16a8 8 0 0 1 16 0"/>
        <line x1="12" y1="12" x2="16" y2="10"/>
      </svg>
    {% when 'range' %}
      <svg class="{{ icon_class }}" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
        <path d="M12 21s-6-5.5-6-10a6 6 0 1 1 12 0c0 4.5-6 10-6 10z"/>
        <circle cx="12" cy="11" r="2"/>
      </svg>
    {% when 'battery' %}
      <svg class="{{ icon_class }}" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
        <rect x="4" y="6" width="14" height="12"/>
        <line x1="20" y1="10" x2="20" y2="14"/>
      </svg>
    {% when 'tire' %}
      <svg class="{{ icon_class }}" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
        <circle cx="12" cy="12" r="9"/>
        <circle cx="12" cy="12" r="3"/>
      </svg>
    {% when 'safety' %}
      <svg class="{{ icon_class }}" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
        <circle cx="12" cy="12" r="9"/>
        <path d="M9 12l2 2 4-4"/>
      </svg>
    {% else %}
      <svg class="{{ icon_class }}" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
        <path d="M13 2L3 14h7l-1 8 10-12h-7l1-8z"/>
      </svg>
  {% endcase %}
{% endif %}