{% liquid
  assign has_product_spec_blocks = false
  for block in section.blocks
    if block.type == 'product_spec'
      assign has_product_spec_blocks = true
      break
    endif
  endfor

  assign spec_acceleration = section.settings.spec_acceleration | default: '0.9s 0-10mph'
  assign spec_motor = section.settings.spec_motor | default: '4160W Peak'
  assign spec_torque = section.settings.spec_torque | default: '190N·m'
  assign spec_top_speed = section.settings.spec_top_speed | default: '45MPH'
  assign spec_range = section.settings.spec_range | default: '40-65 Miles'
  assign spec_battery = section.settings.spec_battery | default: '52V 26Ah'
  assign spec_tire = section.settings.spec_tire | default: 'F14"/R12"'
  assign spec_safety = section.settings.spec_safety | default: 'Magnetic Switch'

  if product != blank
    if product.metafields.custom.spec_acceleration.value != blank
      assign spec_acceleration = product.metafields.custom.spec_acceleration.value
    endif
    if product.metafields.custom.spec_motor.value != blank
      assign spec_motor = product.metafields.custom.spec_motor.value
    endif
    if product.metafields.custom.spec_torque.value != blank
      assign spec_torque = product.metafields.custom.spec_torque.value
    endif
    if product.metafields.custom.spec_top_speed.value != blank
      assign spec_top_speed = product.metafields.custom.spec_top_speed.value
    endif
    if product.metafields.custom.spec_range.value != blank
      assign spec_range = product.metafields.custom.spec_range.value
    endif
    if product.metafields.custom.spec_battery.value != blank
      assign spec_battery = product.metafields.custom.spec_battery.value
    endif
    if product.metafields.custom.spec_tire.value != blank
      assign spec_tire = product.metafields.custom.spec_tire.value
    endif
    if product.metafields.custom.spec_safety.value != blank
      assign spec_safety = product.metafields.custom.spec_safety.value
    endif
  endif
%}

<style>
  .product-specs {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 30px 40px;
    padding: 30px 0;
    width: 100%;
    max-width: 1100px;
    margin: 0 auto;
  }

  .product-specs__item {
    display: flex;
    align-items: flex-start;
    gap: 12px;
    min-width: 0;
  }

  .product-specs__icon {
    width: 40px;
    height: 40px;
    flex-shrink: 0;
  }

  .product-specs__text small {
    display: block;
    color: #888;
    font-size: 13px;
    margin-bottom: 3px;
  }

  .product-specs__text strong {
    display: block;
    font-size: 16px;
    font-weight: 600;
    color: #000;
  }

  @media (max-width: 991px) {
    .product-specs {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 24px;
    }
  }

  @media (max-width: 575px) {
    .product-specs {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 18px;
      padding: 24px 0;
    }
  }
</style>

<div class="product-specs" aria-label="Product specifications">
  {% if has_product_spec_blocks %}
    {% for block in section.blocks %}
      {% if block.type == 'product_spec' %}
        {% liquid
          assign spec_label = block.settings.label | strip
          assign spec_value = block.settings.value | strip
        %}

        {% if spec_label != blank or spec_value != blank %}
          <div class="product-specs__item" {{ block.shopify_attributes }}>
            {% render 'product-spec-icon',
              icon: block.settings.icon,
              custom_icon: block.settings.custom_icon,
              alt: spec_label,
              class: 'product-specs__icon'
            %}
            <div class="product-specs__text">
              {% if spec_label != blank %}
                <small>{{ spec_label | escape }}</small>
              {% endif %}
              {% if spec_value != blank %}
                <strong>{{ spec_value | escape }}</strong>
              {% endif %}
            </div>
          </div>
        {% endif %}
      {% endif %}
    {% endfor %}
  {% else %}
    <div class="product-specs__item">
      {% render 'product-spec-icon', icon: 'acceleration', class: 'product-specs__icon' %}
      <div class="product-specs__text">
        <small>Acceleration</small>
        <strong>{{ spec_acceleration | escape }}</strong>
      </div>
    </div>

    <div class="product-specs__item">
      {% render 'product-spec-icon', icon: 'motor', class: 'product-specs__icon' %}
      <div class="product-specs__text">
        <small>Mid-Drive Motor</small>
        <strong>{{ spec_motor | escape }}</strong>
      </div>
    </div>

    <div class="product-specs__item">
      {% render 'product-spec-icon', icon: 'torque', class: 'product-specs__icon' %}
      <div class="product-specs__text">
        <small>Torque</small>
        <strong>{{ spec_torque | escape }}</strong>
      </div>
    </div>

    <div class="product-specs__item">
      {% render 'product-spec-icon', icon: 'top_speed', class: 'product-specs__icon' %}
      <div class="product-specs__text">
        <small>Top Speed</small>
        <strong>{{ spec_top_speed | escape }}</strong>
      </div>
    </div>

    <div class="product-specs__item">
      {% render 'product-spec-icon', icon: 'range', class: 'product-specs__icon' %}
      <div class="product-specs__text">
        <small>Max Range</small>
        <strong>{{ spec_range | escape }}</strong>
      </div>
    </div>

    <div class="product-specs__item">
      {% render 'product-spec-icon', icon: 'battery', class: 'product-specs__icon' %}
      <div class="product-specs__text">
        <small>Battery</small>
        <strong>{{ spec_battery | escape }}</strong>
      </div>
    </div>

    <div class="product-specs__item">
      {% render 'product-spec-icon', icon: 'tire', class: 'product-specs__icon' %}
      <div class="product-specs__text">
        <small>Off-Road Tire</small>
        <strong>{{ spec_tire | escape }}</strong>
      </div>
    </div>

    <div class="product-specs__item">
      {% render 'product-spec-icon', icon: 'safety', class: 'product-specs__icon' %}
      <div class="product-specs__text">
        <small>Safety Protection</small>
        <strong>{{ spec_safety | escape }}</strong>
      </div>
    </div>
  {% endif %}
</div>