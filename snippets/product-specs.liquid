<style>
  .product-specs {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 30px 40px;
    padding: 30px 0;
    width: 100%;
    max-width: 1100px;
    margin: 0 auto;
  }

  .product-specs__item {
    display: flex;
    align-items: flex-start;
    gap: 12px;
    min-width: 0;
  }

  .product-specs__icon {
    width: 40px;
    height: 40px;
    flex-shrink: 0;
  }

  .product-specs__text small {
    display: block;
    color: #888;
    font-size: 13px;
    margin-bottom: 3px;
  }

  .product-specs__text strong {
    display: block;
    font-size: 16px;
    font-weight: 600;
    color: #000;
  }

  @media (max-width: 991px) {
    .product-specs {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 24px;
    }
  }

  @media (max-width: 575px) {
    .product-specs {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 18px;
      padding: 24px 0;
    }
  }
</style>

