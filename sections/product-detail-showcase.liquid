{% comment %}
  Section: igogomi-product-showcase.liquid
  Place in: sections/
{% endcomment %}

<style>
  :root {
    --text-color: #333;
    --light-gray: #f9f9f9;
    --accent-blue: #00a0e9;
  }

  * {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  body {
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
    line-height: 1.5;
    color: var(--text-color);
    background-color: #fff;
  }

  .igomi-container-wrapper {
            max-width: 1200px;
            margin: 0 auto;
            overflow: hidden;
        }

        /* Banner Responsive Handling */
        .igomi-banner {
            position: relative;
            width: 100%;
            display: block;
        }

        .igomi-banner picture img {
            width: 100%;
            height: auto;
            display: block;
        }

        .igomi-banner-overlay {
            position: absolute;
            top: 50%;
            left: 5%;
            transform: translateY(-50%);
            color: white;
            max-width: 50%;
        }

        .igomi-banner-overlay h2 {
            font-size: clamp(1.5rem, 4vw, 3rem);
            line-height: 1.1;
            text-transform: uppercase;
            font-weight: 800;
        }

        .igomi-banner-overlay--bottom {
            top: auto;
            bottom: 8%;
            transform: none;
        }

        /* Feature Sections */
        .igomi-section-padding {
            padding: 40px 0;
        }

        .igomi-intro-text {
            text-align: left;
            margin-bottom: 30px;
        }

        .igomi-intro-text h3 {
            font-size: 1.2rem;
            color: #888;
            margin-bottom: 5px;
        }

        .igomi-intro-text h2 {
            font-size: 2rem;
            font-weight: 800;
            margin-bottom: 15px;
        }

        /* Cards Grid */
        .igomi-cards-grid {
            display: grid;
            grid-template-columns: repeat(1, 1fr);
            gap: 20px;
            margin-top: 30px;
            align-items: start;
        }

        @media (min-width: 768px) {
            .igomi-cards-grid {
                grid-template-columns: repeat(4, 1fr);
            }
        }

        .igomi-card {
            background: #fff;
            display: flex;
            flex-direction: column;
        }

        .igomi-card img {
            width: 100%;
            aspect-ratio: 1 / 1;
            object-fit: cover;
            display: block;
            margin-bottom: 15px;
            border-radius: 10px;
        }

        .igomi-card h4 {
            font-size: 1rem;
            text-transform: uppercase;
            margin-bottom: 10px;
            font-weight: 700;
        }

        .igomi-card p {
            font-size: 0.9rem;
            color: #666;
            line-height: 1.4;
        }

        /* Secondary Grid Text */
        .igomi-bottom-info {
            padding: 20px 0;
        }

        .igomi-bottom-info h2 {
            font-size: 1.5rem;
            font-weight: 700;
            margin-bottom: 10px;
        }

        .igomi-performance-panel {
            background: #ffffff;
            padding: 28px 20px 30px;
        }

        .igomi-performance-title {
            font-size: clamp(1.1rem, 2vw, 1.55rem);
            line-height: 1.2;
            font-weight: 800;
            color: #242424;
            margin-bottom: 26px;
        }

        .igomi-performance-grid {
            display: grid;
            grid-template-columns: 1fr;
            gap: 22px;
        }

        .igomi-performance-item-header {
            display: flex;
            align-items: center;
            gap: 12px;
            margin-bottom: 8px;
        }

        .igomi-performance-badge {
            width: 26px;
            height: 26px;
            border-radius: 50%;
            background: #f4874c;
            color: #111;
            font-weight: 700;
            font-size: 0.95rem;
            line-height: 26px;
            text-align: center;
            flex-shrink: 0;
        }

        .igomi-performance-item h3 {
            font-size: clamp(0.9rem, 1.1vw, 1.2rem);
            font-weight: 800;
            color: #262626;
            line-height: 1.1;
        }

        .igomi-performance-list {
            margin: 0;
            padding-left: 22px;
            color: #2e2e2e;
            font-size: 0.88rem;
            line-height: 1.5;
        }

        .igomi-performance-list li {
            margin-bottom: 6px;
        }

        .igomi-performance-list strong {
            font-weight: 800;
        }

        @media (min-width: 768px) {
            .igomi-performance-grid {
                grid-template-columns: repeat(2, minmax(0, 1fr));
                gap: 24px 28px;
            }
        }

        @media (min-width: 1100px) {
            .igomi-performance-panel {
                padding: 34px 20px 30px;
            }

            .igomi-performance-grid {
                grid-template-columns: repeat(4, minmax(0, 1fr));
                gap: 28px;
            }
        }

        @media (max-width: 767px) {
            .igomi-container-wrapper {
                padding-left: 12px;
                padding-right: 12px;
            }
        }
</style>

<div class="igomi-container-wrapper">

  {%- comment -%} Banner 1 {%- endcomment -%}
  <section class="igomi-banner">
    <picture>
      {% if section.settings.banner1_desktop_image != blank %}
        <source media="(min-width: 768px)" srcset="{{ section.settings.banner1_desktop_image | image_url: width: 1200 }}">
      {% else %}
        <source media="(min-width: 768px)" srcset="https://cdn.shopify.com/s/files/1/0540/8820/4467/files/kv_7a3364bf-6361-40d4-9e7d-f38dfc362513.jpg">
      {% endif %}
      {% if section.settings.banner1_mobile_image != blank %}
        <img src="{{ section.settings.banner1_mobile_image | image_url: width: 800 }}" alt="{{ section.settings.banner1_alt }}" width="1200" height="600" loading="eager">
      {% else %}
        <img src="https://cdn.shopify.com/s/files/1/0540/8820/4467/files/igogomi01_1d108719-d7e9-447a-a694-0f8a638b9653.jpg" alt="{{ section.settings.banner1_alt }}" width="1200" height="600" loading="eager">
      {% endif %}
    </picture>
  </section>

  {%- comment -%} Banner 2 {%- endcomment -%}
  <section class="igomi-banner">
    <picture>
      {% if section.settings.banner2_desktop_image != blank %}
        <source media="(min-width: 768px)" srcset="{{ section.settings.banner2_desktop_image | image_url: width: 1200 }}">
      {% else %}
        <source media="(min-width: 768px)" srcset="https://cdn.shopify.com/s/files/1/0540/8820/4467/files/kv000_fd83a6e2-bccf-4d35-a457-2c6489567c4e.jpg">
      {% endif %}
      {% if section.settings.banner2_mobile_image != blank %}
        <img src="{{ section.settings.banner2_mobile_image | image_url: width: 800 }}" alt="{{ section.settings.banner2_alt }}" width="1200" height="600" loading="lazy">
      {% else %}
        <img src="https://cdn.shopify.com/s/files/1/0540/8820/4467/files/igogomi02_5b12a774-064e-4a44-bd72-3d7ec1e25846.jpg" alt="{{ section.settings.banner2_alt }}" width="1200" height="600" loading="lazy">
      {% endif %}
    </picture>
  </section>

  <section class="igomi-performance-panel">
        <h2 class="igomi-performance-title">Built to dominate the toughest terrain and tested to exceed every limit.</h2>
        <div class="igomi-performance-grid">
            <article class="igomi-performance-item">
                <div class="igomi-performance-item-header">
                    <span class="igomi-performance-badge">1</span>
                    <h3>Frame Strength</h3>
                </div>
                <ul class="igomi-performance-list">
                    <li><strong>Built to handle 400 lbs static load</strong></li>
                    <li><strong>Load:</strong> 400 lbs Static Load</li>
                </ul>
            </article>
            <article class="igomi-performance-item">
                <div class="igomi-performance-item-header">
                    <span class="igomi-performance-badge">2</span>
                    <h3>Suspension Control</h3>
                </div>
                <ul class="igomi-performance-list">
                    <li><strong>Shock Durability:</strong> 500,000 Compression</li>
                    <li><strong>Bump Sensitivity:</strong> 95% Compliance</li>
                </ul>
            </article>
            <article class="igomi-performance-item">
                <div class="igomi-performance-item-header">
                    <span class="igomi-performance-badge">3</span>
                    <h3>Wheel Precision</h3>
                </div>
                <ul class="igomi-performance-list">
                    <li><strong>Rim Impact:</strong> ASTM F2043 LvL 2</li>
                    <li><strong>Lateral Stiffness:</strong> 75 N/mm</li>
                </ul>
            </article>
            <article class="igomi-performance-item">
                <div class="igomi-performance-item-header">
                    <span class="igomi-performance-badge">4</span>
                    <h3>Brake Confidence</h3>
                </div>
                <ul class="igomi-performance-list">
                    <li><strong>Pad Wear:</strong> &lt; 0.5mm/500 Miles</li>
                    <li><strong>Heat Dissipation:</strong> &lt; 200&#176;C Max Braking</li>
                </ul>
            </article>
        </div>
  </section>

  {%- comment -%} Banner 3 with bottom overlay {%- endcomment -%}
  <section class="igomi-banner">
    <picture>
      {% if section.settings.banner3_desktop_image != blank %}
        <source media="(min-width: 768px)" srcset="{{ section.settings.banner3_desktop_image | image_url: width: 1200 }}">
      {% else %}
        <source media="(min-width: 768px)" srcset="https://cdn.shopify.com/s/files/1/0540/8820/4467/files/igogomi-image.jpg">
      {% endif %}
      {% if section.settings.banner3_mobile_image != blank %}
        <img src="{{ section.settings.banner3_mobile_image | image_url: width: 800 }}" alt="{{ section.settings.banner3_alt }}" width="1200" height="600" loading="lazy">
      {% else %}
        <img src="https://cdn.shopify.com/s/files/1/0540/8820/4467/files/0001_4d5630ec-0ba2-4a73-a95a-b9694fb95f8b.jpg" alt="{{ section.settings.banner3_alt }}" width="1200" height="600" loading="lazy">
      {% endif %}
    </picture>
    {% if section.settings.banner3_overlay_text != blank %}
      <div class="igomi-banner-overlay igomi-banner-overlay--bottom">
        <h2>{{ section.settings.banner3_overlay_text | newline_to_br }}</h2>
      </div>
    {% endif %}
  </section>

  {%- comment -%} Feature Section 1 {%- endcomment -%}
  <div class="igomi-section-padding">
    <div class="igomi-intro-text">
      <h3>{{ section.settings.intro_eyebrow }}</h3>
      <h2>{{ section.settings.intro_heading }}</h2>
      <p>{{ section.settings.intro_body }}</p>
    </div>

    <div class="igomi-cards-grid">
      {% assign card1_index = 0 %}
      {% for block in section.blocks %}
        {% if block.type == 'feature_card_1' %}
          {% assign card1_index = card1_index | plus: 1 %}
          <div class="igomi-card" {{ block.shopify_attributes }}>
            {% if block.settings.card_image != blank %}
              <img src="{{ block.settings.card_image | image_url: width: 800 }}" alt="{{ block.settings.card_alt }}" width="400" height="300" loading="lazy">
            {% else %}
              {% case card1_index %}
                {% when 1 %}
                  <img src="https://cdn.shopify.com/s/files/1/0540/8820/4467/files/a01_8abe84f8-1d7c-40e0-b27b-c963c222742d.jpg" alt="{{ block.settings.card_alt }}" width="400" height="300" loading="lazy">
                {% when 2 %}
                  <img src="https://cdn.shopify.com/s/files/1/0540/8820/4467/files/02a.jpg" alt="{{ block.settings.card_alt }}" width="400" height="300" loading="lazy">
                {% when 3 %}
                  <img src="https://cdn.shopify.com/s/files/1/0540/8820/4467/files/03a.jpg" alt="{{ block.settings.card_alt }}" width="400" height="300" loading="lazy">
                {% when 4 %}
                  <img src="https://cdn.shopify.com/s/files/1/0540/8820/4467/files/04a_b6c0c125-6398-4a1c-9c17-f04c90cf126a.jpg" alt="{{ block.settings.card_alt }}" width="400" height="300" loading="lazy">
              {% endcase %}
            {% endif %}
            <h4>{{ block.settings.card_title }}</h4>
            <p>{{ block.settings.card_body }}</p>
          </div>
        {% endif %}
      {% endfor %}
    </div>
  </div>

  {%- comment -%} Banner 4 with center overlay {%- endcomment -%}
  <section class="igomi-banner">
    <picture>
      {% if section.settings.banner4_desktop_image != blank %}
        <source media="(min-width: 768px)" srcset="{{ section.settings.banner4_desktop_image | image_url: width: 1200 }}">
      {% else %}
        <source media="(min-width: 768px)" srcset="https://cdn.shopify.com/s/files/1/0540/8820/4467/files/igogomikv002.jpg">
      {% endif %}
      {% if section.settings.banner4_mobile_image != blank %}
        <img src="{{ section.settings.banner4_mobile_image | image_url: width: 800 }}" alt="{{ section.settings.banner4_alt }}" width="1200" height="600" loading="lazy">
      {% else %}
        <img src="https://cdn.shopify.com/s/files/1/0540/8820/4467/files/igogomi002a.jpg" alt="{{ section.settings.banner4_alt }}" width="1200" height="600" loading="lazy">
      {% endif %}
    </picture>
    {% if section.settings.banner4_overlay_text != blank %}
      <div class="igomi-banner-overlay">
        <h2>{{ section.settings.banner4_overlay_text | newline_to_br }}</h2>
      </div>
    {% endif %}
  </section>

  {%- comment -%} Feature Section 2 {%- endcomment -%}
  <div class="igomi-section-padding">
    <div class="igomi-bottom-info">
      <h2>{{ section.settings.bottom_heading }}</h2>
    </div>

    <div class="igomi-cards-grid">
      {% assign card2_index = 0 %}
      {% for block in section.blocks %}
        {% if block.type == 'feature_card_2' %}
          {% assign card2_index = card2_index | plus: 1 %}
          <div class="igomi-card" {{ block.shopify_attributes }}>
            {% if block.settings.card_image != blank %}
              <img src="{{ block.settings.card_image | image_url: width: 800 }}" alt="{{ block.settings.card_alt }}" width="400" height="300" loading="lazy">
            {% else %}
              {% case card2_index %}
                {% when 1 %}
                  <img src="https://cdn.shopify.com/s/files/1/0540/8820/4467/files/04.jpg" alt="{{ block.settings.card_alt }}" width="400" height="300" loading="lazy">
                {% when 2 %}
                  <img src="https://cdn.shopify.com/s/files/1/0540/8820/4467/files/02.jpg" alt="{{ block.settings.card_alt }}" width="400" height="300" loading="lazy">
                {% when 3 %}
                  <img src="https://cdn.shopify.com/s/files/1/0540/8820/4467/files/03.jpg" alt="{{ block.settings.card_alt }}" width="400" height="300" loading="lazy">
                {% when 4 %}
                  <img src="https://cdn.shopify.com/s/files/1/0540/8820/4467/files/01_46f9b933-c7aa-4449-b2d1-134e914892f1.jpg" alt="{{ block.settings.card_alt }}" width="400" height="300" loading="lazy">
              {% endcase %}
            {% endif %}
            <h4>{{ block.settings.card_title }}</h4>
            <p>{{ block.settings.card_body }}</p>
          </div>
        {% endif %}
      {% endfor %}
    </div>
  </div>

</div>

